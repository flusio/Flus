{% if origin %}
    {% set origin_url = origin | format_origin_url %}
    {% set origin_label = origin | format_origin_label %}
    {% if origin_url %}
        {{ t('via <a class="anchor--nostyle" href="%s">%s</a>', [
            origin_url | escape,
            origin_label | escape,
        ]) | raw }}
    {% else %}
        {{ t('via %s', [
            origin_label | escape,
        ]) | raw }}
    {% endif %}
{% endif %}
