{% if pagination.numberElements > 0 %}
    <p class="text--center text--secondary">
        {% set count_links = links | length %}
        {% set count_total = pagination.numberElements %}

        {% if count_total <= count_links %}
            {{ t('%s link', '%s links', count_links, [count_links | format_number]) }}
        {% else %}
            {{ t('%s of %s links', [count_links | format_number, count_total | format_number]) }}
        {% endif %}
    </p>
{% endif %}
