<article class="source cols cols--center cols--gap">
    <div class="col--extend cols cols--always cols--center cols--gap">
        <img
            class="source__image"
            alt=""
            src="{{ url_media('covers', source.image_filename, 'collection-card.png') }}"
        >

        <div class="col--extend flow flow--smaller">
            <h3 class="text--bold text--normal">
                <a class="anchor--nostyle" href="{{ url('collection', { id: source.id }) }}">
                    {{ source.name }}
                </a>
            </h3>

            <p class="text--secondary">
                {% if source.isFeed %}
                    <span title="{{ t('Feed of %s website', [source.feedWebsiteHost]) }}">
                        {{ source.feedWebsiteHost }}
                    </span>
                {% else %}
                    {{ t('By') }}
                    {%- for user in source.publishers -%}
                        {% if not loop.first %}, {% endif %}
                        <a class="username" href="{{ url('profile', { id: user.id }) }}">
                            <img class="avatar avatar--mini" alt="" src="{{ url_avatar(user.avatar_filename) }}">
                            {{- user.username -}}
                        </a>
                    {%- endfor -%}
                {% endif %}
            </p>

            <p class="text--secondary">
                <span title="{{ t('Publication frequency') }}">
                    {{ icon('frequency') }}
                    {{ source.publication_frequency_per_year | format_publication_frequency }}
                </span>
            </p>
        </div>
    </div>

    {% if action === 'add' %}
        <form class="text--right" method="post" action="{{ url('add stream source', { id: stream.id, source_id: source.id }) }}" data-turbo-preserve-scroll>
            <button>
                {{ t('Add') }}
            </button>

            <input type="hidden" name="csrf_token" value="{{ csrf_token('streams\\AddSource') }}" />
        </form>
    {% elseif action === 'remove' %}
        <form class="text--right" method="post" action="{{ url('remove stream source', { id: stream.id, source_id: source.id }) }}" data-turbo-preserve-scroll>
            <button>
                {{ t('Remove') }}
            </button>

            <input type="hidden" name="csrf_token" value="{{ csrf_token('streams\\RemoveSource') }}" />
        </form>
    {% endif %}
</article>
