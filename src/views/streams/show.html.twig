{% extends 'layouts/application.html.twig' %}

{% set stream = stream_view.stream %}

{% block title %}{{ stream.name }}{% endblock %}
{% block canonical %}{{ url_full('stream', { id: stream.id }) }}{% endblock %}

{% block layout_header %}
    {{ include('layouts/_header.html.twig', { page: 'stream', tab: 'reading' }) }}
{% endblock %}

{% block layout_sidenav %}
    {{ include('layouts/_sidenav.html.twig', { navigation: reading_navigation(current: stream.id) }) }}
{% endblock %}

{% block back %}
    {{ include('layouts/_back.html.twig', { title: stream.name, reset: true }) }}
{% endblock %}

{% block body %}
    <div class="cols cols--gap-large">
        <div class="col--size3 text--center">
            <img
                class="illustration"
                alt=""
                src="{{ url_media('covers', stream.image_filename, 'collection-card.png') }}"
            >
        </div>

        <div class="col--extend flow">
            <h1 class="text--break">{{ stream.name }}</h1>

            <p class="stack stack--gap">
                <span title="{{ t('Publication frequency') }}">
                    {{ icon('frequency') }}
                    {{ stream.publicationFrequencyPerYear | format_publication_frequency }}
                </span>
            </p>

            <p>
                {{ t('By') }}
                <a class="username" href="{{ url('profile', { id: stream.owner.id }) }}">
                    <img class="avatar avatar--mini" alt="" src="{{ url_avatar(stream.owner.avatar_filename) }}">
                    {{- stream.owner.username -}}
                </a>
            </p>

            {% if stream.description %}
                <div class="text-container">
                    {{ stream.descriptionAsHtml | raw }}
                </div>
            {% endif %}
        </div>
    </div>

    {% if can(app.user, 'update', stream) %}
        <div class="panel panel--rounded stack stack--gap-small">
            <a class="button" href="{{ url('edit stream sources', { id: stream.id }) }}">
                {{ t('Manage sources') }}
            </a>
        </div>
    {% endif %}

    <section class="filters">
        <div class="filters__section">
            <form class="flow" method="get" action="">
                <div class="cols cols--always cols--center cols--gap">
                    <div class="col--size9 form-group">
                        <label for="stream-at">
                            {{ t('Date') }}
                        </label>

                        <select
                            id="stream-at"
                            name="at"
                        >
                            {% for day in stream_view.period %}
                                <option
                                    value="{{ day.format('Y-m-d') }}"
                                    {{ stream_view.isAt(day) ? 'selected' : '' }}
                                >
                                    {{ d(day) }}
                                    ({{ stream_view.countByDay(day, context_user: app.user) }})
                                </option>
                            {% endfor %}
                        </select>
                    </div>

                    <div class="col--size3 form-group">
                        <label for="stream-days">
                            {{ t('Number of days') }}
                        </label>

                        <input
                            type="number"
                            id="stream-days"
                            name="days"
                            value="{{ stream_view.days }}"
                            min="1"
                            max="7"
                        >
                    </div>
                </div>

                <div class="text--right">
                    <button
                        type="submit"
                        class="button--primary button--big button--animated"
                    >
                        {{ t('Search') }}
                        {{ icon('arrow-right') }}
                    </button>
                </div>
            </form>
        </div>

        <div class="filters__section flow">
            {% set sources_and_counts = stream_view.countedSources(context_user: app.user) %}

            <p class="text--bold">
                {{ t('Sources (%d)', [sources_and_counts | length]) }}
            </p>

            <div class="stack stack--gap-small">
                {% for source_and_count in sources_and_counts %}
                    {% set source = source_and_count[0] %}
                    {% set count_all_links = source_and_count[1] %}
                    {% set count_unread_links = source_and_count[2] %}

                    <a
                        class="source source--button cols cols--always cols--center cols--gap"
                        href="{{ stream_view.urlSource(source) }}"
                        {% if stream_view.isSourceSelected(source) %}aria-current="page"{% endif %}
                        title="{{ t('%s : %d link', '%s : %d links', count_all_links, [source.name, count_all_links]) }} {% if count_unread_links > 0 %}{{ t('(has unread)') }}{% endif %}"
                    >
                        <img
                            class="source__image"
                            alt=""
                            src="{{ url_media('covers', source.image_filename, 'collection-card.png') }}"
                        >

                        <div class="col--extend flow flow--smaller">
                            <div class="source__name">
                                {{ source.name }}
                            </div>

                            <div class="text--secondary text--right">
                                {% if count_unread_links > 0 %}
                                    <span class="source__unread-dot">
                                    </span>
                                {% endif %}

                                {{ count_all_links }}
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>

        <div class="filters__section">
            <div class="stack stack--gap-smaller">
                <a
                    class="button"
                    href="{{ stream_view.urlStatus('all') }}"
                    {% if stream_view.isStatusSelected('all') %}aria-current="page"{% endif %}
                >
                    {{ t('All') }}
                </a>

                <a
                    class="button"
                    href="{{ stream_view.urlStatus('unread') }}"
                    {% if stream_view.isStatusSelected('unread') %}aria-current="page"{% endif %}
                >
                    {{ t('Unread') }}
                </a>

                <a
                    class="button"
                    href="{{ stream_view.urlStatus('read-later') }}"
                    {% if stream_view.isStatusSelected('read-later') %}aria-current="page"{% endif %}
                >
                    {{ t('To read') }}
                </a>

                <a
                    class="button"
                    href="{{ stream_view.urlStatus('read') }}"
                    {% if stream_view.isStatusSelected('read') %}aria-current="page"{% endif %}
                >
                    {{ t('Links read') }}
                </a>
            </div>
        </div>
    </section>

    {% set links_timeline = stream_view.linksTimeline(context_user: app.user) %}

    {% if not links_timeline.empty %}
        <div class="flow flow--large" data-controller="zindex-inverser">
            {% for date_group in links_timeline.datesGroups %}
                <section class="group flow">
                    <header class="group__header" data-zindex-inverser-target="item">
                        <h2 class="group__title">
                            {{ d(date_group.date, 'dd MMMM') }}
                        </h2>

                        <div class="group__separator"></div>
                    </header>

                    <div class="group__body flow">
                        {% set links = date_group.links %}

                        {% if links %}
                            <div class="grid">
                                {% for link in date_group.links %}
                                    {{ include('links/_link.html.twig', {
                                        link: link,
                                        display_read_later: 'auto',
                                        display_mark_as_read: 'auto',
                                        storing_must_mark_as_read: true,
                                    })}}
                                {% endfor %}
                            </div>
                        {% endif %}

                        {% for source_group in date_group.sourceGroups %}
                            <div class="source-group flow flow--small">
                                <div class="source-group__header cols cols--always cols--gap cols--center">
                                    <h3 class="source-group__title">
                                        {{ source_group.source.name() }}
                                    </h3>

                                    <span class="col--noshrink text--secondary">
                                        {{ t('%s link', '%s links', source_group.links | length, [source_group.links | length]) }}
                                    </span>
                                </div>

                                <div class="source-group__body grid">
                                    {% for link in source_group.links %}
                                        {{ include('links/_link.html.twig', {
                                            link: link,
                                            display_read_later: 'auto',
                                            display_mark_as_read: 'auto',
                                            storing_must_mark_as_read: true,
                                        }) }}
                                    {% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </section>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
