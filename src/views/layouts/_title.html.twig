{# response_code is declared on AfterAction in the BaseController.
 # However, it can be undefined on some errors (e.g. a user tries to access an
 # non existing page), so we add "Error:" in this situation too.
 #}
{%- if response_code is not defined or response_code >= 400 -%}
    {%- set title = t('Error: ') ~ title -%}
{%- endif -%}
{%- if is_environment('development') -%}
    {%- set title = '[dev] ' ~ title -%}
{%- endif -%}
{%- set title = title ~ ' · ' ~ app.brand -%}
{# It is fine to render raw title as the content is passed from a block which
 # is already escaped. This avoids to escape title twice. #}
{{- title | raw -}}
