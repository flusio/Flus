{% if element.is('group') %}
    <div class="flow flow--smaller">
        {% if element.action %}
            <div class="cols cols--always cols--center cols--gap-smaller">
                <h2 class="sidenav__menu-title col--extend">{{ element.label }}</h2>

                <button
                    type="button"
                    class="button--icon"
                    title="{{ element.action.label }}"
                    data-controller="modal-opener"
                    data-action="modal-opener#fetch"
                    data-modal-opener-href-value="{{ element.action.url }}"
                    aria-haspopup="dialog"
                    aria-controls="modal"
                >
                    {{ icon(element.action.icon) }}
                </button>
            </div>
        {% else %}
            <h2 class="sidenav__menu-title">{{ element.label }}</h2>
        {% endif %}

        {% for item in element.items %}
            {{ include('layouts/_sidenav_element.html.twig', { element: item }) }}
        {% endfor %}
    </div>
{% elseif element.is('placeholder') %}
    <p class="panel panel--grey panel--rounded text--center text--smaller">
        {{ element.label }}
    </p>
{% else %}
    <a
        class="sidenav__menu-item"
        href="{{ element.url }}"
        {{ navigation.isCurrent(element) ? 'aria-current="page"' : '' }}
    >
        {% if element.icon %}
            {{ icon(element.icon) }}
        {% endif %}

        {{ element.label }}
    </a>
{% endif %}
